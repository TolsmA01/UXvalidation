{
  "_comment": "UX Guidelines Template — fill in your brand values and drop this file into UX Validator",
  "name": "My Brand Design System",
  "version": "1.0.0",

  "colors": {
    "primary": "#6366F1",
    "primaryDark": "#4F46E5",
    "primaryLight": "#EEF2FF",
    "secondary": "#8B5CF6",
    "accent": "#EC4899",
    "success": "#10B981",
    "warning": "#F59E0B",
    "error": "#EF4444",
    "background": "#FFFFFF",
    "surface": "#F8FAFC",
    "surfaceAlt": "#F1F5F9",
    "text": {
      "primary": "#0F172A",
      "secondary": "#64748B",
      "disabled": "#CBD5E1",
      "inverse": "#FFFFFF"
    },
    "border": "#E2E8F0"
  },

  "typography": {
    "fontFamilies": {
      "heading": "Inter",
      "body": "Inter",
      "mono": "JetBrains Mono"
    },
    "fontSizes": {
      "xs":   "12px",
      "sm":   "14px",
      "base": "16px",
      "lg":   "18px",
      "xl":   "20px",
      "2xl":  "24px",
      "3xl":  "30px",
      "4xl":  "36px",
      "5xl":  "48px",
      "6xl":  "60px"
    },
    "fontWeights": {
      "regular":   400,
      "medium":    500,
      "semibold":  600,
      "bold":      700,
      "extrabold": 800
    },
    "lineHeights": {
      "tight":   1.25,
      "snug":    1.375,
      "normal":  1.5,
      "relaxed": 1.625,
      "loose":   2.0
    },
    "letterSpacing": {
      "tight":  "-0.025em",
      "normal": "0em",
      "wide":   "0.025em",
      "wider":  "0.05em",
      "widest": "0.1em"
    }
  },

  "spacing": {
    "0":   "0px",
    "1":   "4px",
    "2":   "8px",
    "3":   "12px",
    "4":   "16px",
    "5":   "20px",
    "6":   "24px",
    "8":   "32px",
    "10":  "40px",
    "12":  "48px",
    "16":  "64px",
    "20":  "80px",
    "24":  "96px"
  },

  "borderRadius": {
    "none": "0px",
    "sm":   "4px",
    "md":   "8px",
    "lg":   "12px",
    "xl":   "16px",
    "2xl":  "24px",
    "full": "9999px"
  },

  "shadows": {
    "xs":  "0 1px 2px 0 rgba(0,0,0,0.05)",
    "sm":  "0 1px 3px 0 rgba(0,0,0,0.10)",
    "md":  "0 4px 6px -1px rgba(0,0,0,0.10)",
    "lg":  "0 10px 15px -3px rgba(0,0,0,0.10)",
    "xl":  "0 20px 25px -5px rgba(0,0,0,0.10)",
    "2xl": "0 25px 50px -12px rgba(0,0,0,0.25)"
  },

  "components": {
    "button": {
      "primary": {
        "background": "#6366F1",
        "text": "#FFFFFF",
        "borderRadius": "8px",
        "paddingX": "16px",
        "paddingY": "10px",
        "fontSize": "14px",
        "fontWeight": 600
      },
      "secondary": {
        "background": "transparent",
        "border": "1px solid #E2E8F0",
        "text": "#0F172A",
        "borderRadius": "8px"
      },
      "danger": {
        "background": "#EF4444",
        "text": "#FFFFFF"
      }
    },
    "input": {
      "border": "1px solid #E2E8F0",
      "borderRadius": "8px",
      "focusBorder": "#6366F1",
      "background": "#FFFFFF",
      "fontSize": "14px",
      "paddingX": "12px",
      "paddingY": "8px"
    },
    "card": {
      "background": "#FFFFFF",
      "border": "1px solid #E2E8F0",
      "borderRadius": "12px",
      "padding": "24px",
      "shadow": "0 1px 3px 0 rgba(0,0,0,0.10)"
    },
    "badge": {
      "borderRadius": "9999px",
      "paddingX": "8px",
      "paddingY": "2px",
      "fontSize": "12px",
      "fontWeight": 500
    },
    "navigation": {
      "background": "#0F172A",
      "text": "#FFFFFF",
      "activeText": "#6366F1",
      "height": "64px"
    },
    "table": {
      "headerBackground": "#F8FAFC",
      "rowAltBackground": "#F1F5F9",
      "borderColor": "#E2E8F0",
      "fontSize": "14px"
    }
  },

  "breakpoints": {
    "sm":  "640px",
    "md":  "768px",
    "lg":  "1024px",
    "xl":  "1280px",
    "2xl": "1536px"
  },

  "accessibility": {
    "minContrastRatioBody": 4.5,
    "minContrastRatioLarge": 3.0,
    "minTouchTargetSize": "44px",
    "focusVisible": "2px solid #6366F1"
  },

  "motion": {
    "durationFast":   "150ms",
    "durationNormal": "250ms",
    "durationSlow":   "400ms",
    "easing":         "cubic-bezier(0.4, 0, 0.2, 1)"
  }
}

# Copy this file to .env and fill in your values.
# You only need ONE key — pick the provider you want to use.
# If none are set here, users can enter their key directly in the browser UI.

# ── ANTHROPIC CLAUDE (Recommended for UX analysis) ────────────────────────────
# Best visual comprehension and design system understanding.
# Get your free key at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OPENAI GPT-4o ─────────────────────────────────────────────────────────────
# Great quality. Good if you already have an OpenAI subscription.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── GOOGLE GEMINI ─────────────────────────────────────────────────────────────
# Free tier available with generous quota. Fast and affordable.
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-your-gemini-key-here

# ── PORT ──────────────────────────────────────────────────────────────────────
PORT=3000
